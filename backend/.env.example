# Digital Signature Capstone - local development configuration
# Copy this file to backend/.env. Never commit real production secrets.

NODE_ENV=development
PORT=3000
PUBLIC_VERIFY_URL=http://localhost:3000/api/public/documents/verify

# Authentication
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRES_IN=24h

# One-time signing requests
SIGNING_REQUEST_TTL_SECONDS=300
CITIZEN_SIGNING_REQUEST_TTL_SECONDS=300
CITIZEN_SIGNING_REQUIRED=true

# PKI and trust services
PKI_ROOT_CA_CERT_PATH=../pki/root-ca/root-ca.crt
PKI_OFFICERS_DIRECTORY=../pki/officers
PKI_REQUIRE_CERTIFICATE=true
PKI_OFFICER_CERT_PATH=../pki/officers/OFFICER-001/v1/officer.crt
PKI_OFFICER_PRIVATE_KEY_PATH=../pki/officers/OFFICER-001/v1/officer.key
PKI_OFFICER_CERT_FINGERPRINT_SHA256=
PKI_CRL_PATH=../pki/root-ca/root-ca.crl
PKI_CRL_CONFIG_PATH=../pki/config/openssl-ca.cnf
PKI_REQUIRE_CRL=true
PKI_OCSP_RESPONDER_CERT_PATH=../pki/ocsp/ocsp-responder.crt
PKI_OCSP_RESPONDER_KEY_PATH=../pki/ocsp/ocsp-responder.key
PKI_OCSP_RESPONSE_TTL_SECONDS=300
PKI_OCSP_ALLOW_CRL_FALLBACK=true
PKI_TSA_CERT_PATH=../pki/tsa/tsa.crt
PKI_TSA_KEY_PATH=../pki/tsa/tsa.key
PKI_TSA_DEFAULT_POLICY=1.3.6.1.4.1.55555.1.7.1
OPENSSL_BIN=openssl
PYTHON_BIN=python

# Authenticated remote signing service
TSP_MODE=http
TSP_URL=http://127.0.0.1:3400
TSP_HOST=127.0.0.1
TSP_PORT=3400
TSP_CLIENT_ID=portal-api
TSP_SHARED_SECRET=replace-with-a-long-random-tsp-secret
TSP_ALLOWED_CLOCK_SKEW_SECONDS=300
TSP_REQUEST_TIMEOUT_MS=120000
TSP_ALLOW_LOCAL_FALLBACK=false
TSP_STORAGE_PATH=tsp-service/storage

# Officer remote signing through SoftHSM / PKCS#11
SIGNING_PROVIDER=softhsm
SIGNING_PROVIDER_FAIL_CLOSED=true
SOFTHSM2_UTIL_BIN=softhsm2-util
PKCS11_TOOL_BIN=pkcs11-tool
SOFTHSM_TOKEN_LABEL=NT219-TSP
SOFTHSM_SO_PIN=12345678
SOFTHSM_USER_PIN=123456
SOFTHSM_OPENSSL_MODE=provider
SOFTHSM_PIN_MODE=environment
SOFTHSM_RUNTIME_PROBE=true
SOFTHSM_OPENSSL_PROVIDER_NAME=pkcs11prov
SOFTHSM_PKCS11_PROVIDER_PATH=
SOFTHSM_PKCS11_MODULE_PATH=
SOFTHSM2_CONF=
SOFTHSM_PKCS11_URI_TEMPLATE=pkcs11:token={token};object={label};id={id};type=private

# Sealed external archive
LTV_ARCHIVE_PATH=storage/archive
LTV_ARCHIVE_REQUIRED=true
ARCHIVE_SEAL_KEY_PATH=../pki/archive/archive-seal.key
ARCHIVE_SEAL_CERT_PATH=../pki/archive/archive-seal.crt
ARCHIVE_SERVICE_HOST=127.0.0.1
ARCHIVE_SERVICE_PORT=3600

# Local Client Agent
CLIENT_AGENT_URL=http://127.0.0.1:3500
CLIENT_AGENT_HOST=127.0.0.1
CLIENT_AGENT_PORT=3500
CLIENT_AGENT_CLIENT_ID=portal-api
CLIENT_AGENT_SHARED_SECRET=replace-with-a-long-random-client-agent-secret
CLIENT_AGENT_ALLOWED_CLOCK_SKEW_SECONDS=300
CLIENT_AGENT_REQUEST_TIMEOUT_MS=120000
CLIENT_AGENT_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Citizen PKCS#11 token
CLIENT_AGENT_SOFTHSM2_UTIL_BIN=softhsm2-util
CLIENT_AGENT_PKCS11_TOOL_BIN=pkcs11-tool
CLIENT_AGENT_OPENSSL_BIN=openssl
CLIENT_AGENT_PKCS11_TOKEN_LABEL=NT219-CITIZEN
CLIENT_AGENT_PKCS11_SO_PIN=87654321
CLIENT_AGENT_PKCS11_USER_PIN=654321
CLIENT_AGENT_PKCS11_PROVIDER_NAME=pkcs11prov
CLIENT_AGENT_PKCS11_PROVIDER_PATH=
CLIENT_AGENT_PKCS11_MODULE_PATH=
CLIENT_AGENT_SOFTHSM2_CONF=

# Remote signing OTP
REMOTE_OTP_REQUIRED=true
REMOTE_OTP_TTL_SECONDS=120
REMOTE_OTP_AUTHORIZATION_TTL_SECONDS=120
REMOTE_OTP_MAX_ATTEMPTS=5
REMOTE_OTP_DEMO_EXPOSE=true
REMOTE_OTP_SECRET=replace-with-a-long-random-otp-secret

# Benchmark
BENCHMARK_DEFAULT_RUNS=3
